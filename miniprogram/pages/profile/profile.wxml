<view class="container">
  <view wx:if="{{!isLoggedIn}}" class="guest-shell">
    <view class="guest-card">
      <view class="guest-badge">
        <text class="guest-badge-text">ME</text>
      </view>
      <text class="guest-title">登录后保存你的资料</text>
      <text class="guest-desc">用户名、个性签名、头像和学校信息都会跟着课表一起保存下来。</text>
    </view>

    <view class="guest-panel">
      <view class="guest-line">
        <text class="guest-line-label">用户名</text>
        <text class="guest-line-value">登录后填写</text>
      </view>
      <view class="guest-line">
        <text class="guest-line-label">个性签名</text>
        <text class="guest-line-value">登录后填写</text>
      </view>
      <view class="guest-line">
        <text class="guest-line-label">头像</text>
        <text class="guest-line-value">支持自定义</text>
      </view>

      <view class="guest-agreement-box" bindtap="onToggleGuestAgreement">
        <view class="guest-agreement-check {{agreedGuest ? 'checked' : ''}}">
          <text wx:if="{{agreedGuest}}" class="guest-agreement-check-text">✓</text>
        </view>
        <view class="guest-agreement-copy">
          <text class="guest-agreement-text">我已阅读并同意</text>
          <text class="guest-agreement-link" catchtap="goToUserAgreement">《用户服务协议》</text>
          <text class="guest-agreement-text">和</text>
          <text class="guest-agreement-link" catchtap="goToPrivacyPolicy">《隐私政策》</text>
        </view>
      </view>

      <view class="guest-tip">登录前请先勾选协议，同意后再继续微信登录。</view>
      <view class="cta-button cta-primary guest-login-btn {{agreedGuest ? '' : 'cta-disabled'}}" bindtap="goToLogin">微信登录</view>
    </view>
  </view>

  <block wx:else>
    <view class="user-card">
      <view class="avatar-action" bindtap="onChooseAvatar">
        <image class="avatar" src="{{user.avatar}}" wx:if="{{user.avatar}}" mode="aspectFill" />
        <view class="avatar-placeholder" wx:else>
          <text class="avatar-letter">{{user.avatarLetter || '我'}}</text>
        </view>
        <view class="avatar-tip">换头像</view>
      </view>

      <view class="user-info">
        <view class="name-row" bindtap="onSetNickname">
          <text class="nickname">{{user.nickname || '微信用户'}}</text>
          <text class="edit-inline">修改</text>
        </view>
        <text class="school" wx:if="{{user.school}}">{{user.school}}</text>
        <view class="signature-card" bindtap="onSetSignature">
          <text class="signature-label">个性签名</text>
          <text class="signature-text">{{user.signature || '点这里写一句你想展示的话'}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{restrictions.length}}" class="restriction-card" bindtap="goToAccountStatus">
      <view class="restriction-head">
        <text class="restriction-title">当前有功能限制，请去状态中心查看</text>
        <text class="restriction-link">查看状态 ></text>
      </view>
      <view class="restriction-list">
        <view class="restriction-item" wx:for="{{restrictions}}" wx:key="key">
          <text class="restriction-name">{{item.label}}</text>
          <text class="restriction-detail">{{item.detail}}</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">资料</text>
      </view>

      <view class="info-item" bindtap="onSetNickname">
        <text class="info-label">用户名</text>
        <view class="info-right">
          <text class="info-value">{{user.nickname || '点击填写'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>

      <view class="info-item" bindtap="onSetSignature">
        <text class="info-label">个性签名</text>
        <view class="info-right">
          <text class="info-value multiline">{{user.signature || '点击填写'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>

      <view class="info-item" bindtap="onChooseAvatar">
        <text class="info-label">自定义头像</text>
        <view class="info-right">
          <text class="info-value">{{user.avatar ? '已设置' : '点击上传'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>

      <view class="info-item" bindtap="onSetSchool">
        <text class="info-label">学校</text>
        <view class="info-right">
          <text class="info-value">{{user.school || '点击填写'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>

      <view class="info-item" bindtap="onSetMajor">
        <text class="info-label">专业</text>
        <view class="info-right">
          <text class="info-value">{{user.major || '点击填写'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>

      <view class="info-item" bindtap="onSetGrade">
        <text class="info-label">年级</text>
        <view class="info-right">
          <text class="info-value">{{user.grade || '点击填写'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">操作</text>
      </view>

      <view class="menu-item" bindtap="goToNotes">
        <text class="menu-label">我的笔记</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToAccountStatus">
        <text class="menu-label">账号状态</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="onClearCourses">
        <text class="menu-label">清空课表</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToSettings">
        <text class="menu-label">默认课表</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToSettings">
        <text class="menu-label">提醒设置</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToNotificationCenter">
        <text class="menu-label">通知中心</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToAppeals">
        <text class="menu-label">申诉中心</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToAboutUs">
        <text class="menu-label">关于我们</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToFeedback">
        <text class="menu-label">留言反馈</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="cta-button cta-outline logout-btn" bindtap="onLogout">退出登录</view>
  </block>
</view>
