<view class="container">
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="login-prompt">
    <view class="avatar-wrapper">
      <view class="avatar-placeholder" style="width:120rpx;height:120rpx;font-size:60rpx;line-height:120rpx;text-align:center;border-radius:50%;background:#f0f0f0;">👤</view>
    </view>
    <text style="margin-top:24rpx;font-size:32rpx;color:#666;">登录后可查看个人信息</text>
    <button class="login-btn" style="margin-top:32rpx;background:#4F46E5;color:#fff;border-radius:16rpx;font-size:30rpx;padding:0 60rpx;" bindtap="goToLogin">微信登录</button>
  </view>

  <!-- 已登录状态 -->
  <block wx:else>
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar-wrapper">
      <image class="avatar" src="{{user.avatar}}" wx:if="{{user.avatar}}" />
      <view class="avatar-placeholder" wx:else>👤</view>
    </view>
    <view class="user-info">
      <text class="nickname">{{user.nickname || '点击设置昵称'}}</text>
      <text class="school" wx:if="{{user.schoolName}}">{{user.schoolName}}</text>
    </view>
  </view>

  <!-- 信息列表 -->
  <view class="info-section">
    <view class="info-item" bindtap="onSetSchool">
      <view class="info-left">
        <text class="info-icon">🎓</text>
        <text class="info-label">学校</text>
      </view>
      <view class="info-right">
        <text class="info-value">{{user.school || '未设置'}}</text>
        <text class="info-arrow">›</text>
      </view>
    </view>
    <view class="info-item" bindtap="onSetMajor">
      <view class="info-left">
        <text class="info-icon">📚</text>
        <text class="info-label">专业</text>
      </view>
      <view class="info-right">
        <text class="info-value">{{user.major || '未设置'}}</text>
        <text class="info-arrow">›</text>
      </view>
    </view>
    <view class="info-item" bindtap="onSetGrade">
      <view class="info-left">
        <text class="info-icon">📅</text>
        <text class="info-label">年级</text>
      </view>
      <view class="info-right">
        <text class="info-value">{{user.grade || '未设置'}}</text>
        <text class="info-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onClearCourses">
      <view class="menu-left">
        <text class="menu-icon">🗑️</text>
        <text class="menu-label">清空课程表</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <view class="menu-left">
        <text class="menu-icon">⚙️</text>
        <text class="menu-label">提醒设置</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">🔔</text>
        <text class="menu-label">通知管理</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-label">关于我们</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </block>
</view>

<!-- 底部导航 -->
<view class="bottom-nav">
  <view class="nav-item" bindtap="goToIndex">
    <text class="icon">🏠</text>
    <text class="label">首页</text>
  </view>
  <view class="nav-item" bindtap="goToCourses">
    <text class="icon">📅</text>
    <text class="label">课表</text>
  </view>
  <view class="nav-item" bindtap="goToImport">
    <text class="icon">📷</text>
    <text class="label">导入</text>
  </view>
  <view class="nav-item active" bindtap="goToProfile">
    <text class="icon">👤</text>
    <text class="label">我的</text>
  </view>
</view>
