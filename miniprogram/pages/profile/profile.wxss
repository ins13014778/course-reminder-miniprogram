.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(201, 111, 59, 0.10), transparent 28%),
    linear-gradient(180deg, #fffdf8 0%, #f5f1e8 100%);
  padding: 28rpx 24rpx 56rpx;
  box-sizing: border-box;
}

.guest-shell {
  padding-top: 24rpx;
}

.guest-card {
  background: #fffdf8;
  border: 2rpx solid rgba(31, 58, 46, 0.08);
  border-radius: 34rpx;
  padding: 34rpx 28rpx;
  box-shadow: 0 20rpx 48rpx rgba(54, 45, 32, 0.08);
}

.guest-badge {
  width: 108rpx;
  height: 108rpx;
  border-radius: 28rpx;
  background: #1f3a2e;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 26rpx;
}

.guest-badge-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fffdf8;
  letter-spacing: 4rpx;
}

.guest-title {
  display: block;
  font-size: 48rpx;
  line-height: 1.2;
  color: #1f2b23;
  font-weight: 700;
}

.guest-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.75;
  color: #6b6a63;
}

.guest-panel {
  margin-top: 20rpx;
  background: #1f3a2e;
  border-radius: 28rpx;
  padding: 26rpx 24rpx 30rpx;
}

.guest-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 253, 248, 0.12);
}

.guest-line:last-of-type {
  border-bottom: none;
}

.guest-line-label {
  color: #fffdf8;
  font-size: 26rpx;
}

.guest-line-value {
  color: rgba(255, 253, 248, 0.68);
  font-size: 24rpx;
}

.cta-button {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
}

.cta-primary {
  background: #c96f3b;
  color: #fffdf8;
}

.cta-outline {
  background: #fff1ea;
  color: #b65429;
  border: 2rpx solid rgba(201, 111, 59, 0.16);
}

.guest-login-btn {
  margin-top: 24rpx;
}

.user-card {
  background: #1f3a2e;
  border-radius: 30rpx;
  padding: 34rpx 28rpx;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 22rpx;
}

.avatar-action {
  width: 132rpx;
}

.avatar,
.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.avatar {
  background: #d9d9d9;
}

.avatar-placeholder {
  background: rgba(255, 253, 248, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-letter {
  color: #fffdf8;
  font-size: 42rpx;
  font-weight: 700;
}

.avatar-tip {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: rgba(255, 253, 248, 0.72);
  text-align: center;
}

.user-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nickname {
  display: block;
  font-size: 36rpx;
  color: #fffdf8;
  font-weight: 700;
}

.edit-inline {
  font-size: 22rpx;
  color: rgba(255, 253, 248, 0.7);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 248, 0.1);
}

.school {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 253, 248, 0.72);
}

.signature-card {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 253, 248, 0.1);
}

.signature-label {
  display: block;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 253, 248, 0.55);
}

.signature-text {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #fffdf8;
}

.restriction-card {
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #fff4eb 0%, #fffaf5 100%);
  border: 2rpx solid rgba(201, 111, 59, 0.16);
  box-shadow: 0 14rpx 34rpx rgba(201, 111, 59, 0.08);
}

.restriction-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.restriction-title {
  font-size: 28rpx;
  color: #8a4a25;
  font-weight: 700;
}

.restriction-link {
  font-size: 24rpx;
  color: #c96f3b;
  font-weight: 600;
}

.restriction-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.restriction-item {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.82);
}

.restriction-name {
  display: block;
  font-size: 26rpx;
  color: #8a4a25;
  font-weight: 600;
}

.restriction-detail {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #8f6d59;
}

.section-card {
  background: #fffdf8;
  border-radius: 24rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
  border: 2rpx solid rgba(31, 58, 46, 0.06);
}

.section-head {
  padding: 22rpx 24rpx 10rpx;
}

.section-title {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: #9b907f;
}

.info-item,
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #efe7da;
}

.info-item:last-child,
.menu-item:last-child {
  border-bottom: none;
}

.info-label,
.menu-label {
  font-size: 28rpx;
  color: #27352d;
}

.info-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  max-width: 60%;
}

.info-value {
  font-size: 26rpx;
  color: #8f8b81;
  text-align: right;
}

.info-value.multiline {
  line-height: 1.5;
}

.info-arrow,
.menu-arrow {
  font-size: 30rpx;
  color: #b4ab9d;
}

.logout-btn {
  margin-top: 10rpx;
  border-radius: 20rpx;
}
.guest-agreement-box {
  margin-top: 22rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 253, 248, 0.08);
}

.guest-agreement-check {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 253, 248, 0.58);
  display: flex;
  align-items: center;
  justify-content: center;
}

.guest-agreement-check.checked {
  background: #c96f3b;
  border-color: #c96f3b;
}

.guest-agreement-check-text {
  color: #fffdf8;
  font-size: 20rpx;
  font-weight: 700;
}

.guest-agreement-copy {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.8;
}

.guest-agreement-text {
  color: rgba(255, 253, 248, 0.78);
}

.guest-agreement-link {
  color: #ffd7bf;
  font-weight: 600;
}

.guest-tip {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(255, 253, 248, 0.64);
}

.cta-disabled {
  opacity: 0.56;
}
