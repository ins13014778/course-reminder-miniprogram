.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(30, 59, 47, 0.1), transparent 24%),
    radial-gradient(circle at bottom right, rgba(201, 111, 59, 0.12), transparent 26%),
    linear-gradient(180deg, #fbf7ef 0%, #f1eadf 100%);
}

.hero-card,
.panel-card,
.footer-card {
  padding: 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  background: rgba(255, 251, 245, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(53, 44, 30, 0.08);
}

.panel-card,
.footer-card {
  margin-top: 20rpx;
}

.eyebrow {
  display: block;
  font-size: 18rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.hero-title {
  display: block;
  margin-top: 10rpx;
  font-size: 52rpx;
  line-height: 1.04;
  color: #1e2b23;
  font-weight: 700;
}

.hero-sub,
.panel-copy,
.contact-value,
.footer-copy {
  display: block;
  font-size: 24rpx;
  line-height: 1.8;
  color: #857a67;
}

.hero-sub {
  margin-top: 14rpx;
}

.panel-title,
.contact-label {
  display: block;
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.panel-copy {
  margin-top: 14rpx;
  white-space: pre-wrap;
}

.contact-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(30, 59, 47, 0.04);
}

.contact-value {
  margin-top: 8rpx;
}

.footer-card {
  text-align: center;
}
