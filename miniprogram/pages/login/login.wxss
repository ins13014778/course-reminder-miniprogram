.container {
  min-height: 100vh;
  padding: 44rpx 28rpx 60rpx;
  background:
    radial-gradient(circle at top left, rgba(201, 111, 59, 0.14), transparent 34%),
    linear-gradient(180deg, #fffdf8 0%, #f5f1e8 100%);
  box-sizing: border-box;
}

.hero-card {
  margin-top: 60rpx;
  background: #fffdf8;
  border: 2rpx solid rgba(31, 58, 46, 0.08);
  border-radius: 36rpx;
  padding: 40rpx 32rpx 34rpx;
  box-shadow: 0 24rpx 60rpx rgba(54, 45, 32, 0.08);
}

.hero-mark {
  width: 108rpx;
  height: 108rpx;
  border-radius: 28rpx;
  background: #1f3a2e;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.hero-mark-text {
  color: #fffdf8;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.eyebrow {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #8e8a80;
}

.title {
  font-size: 62rpx;
  line-height: 1.18;
  color: #1f2b23;
  font-weight: 700;
}

.desc {
  font-size: 28rpx;
  line-height: 1.75;
  color: #6b6a63;
}

.feature-strip {
  margin-top: 34rpx;
  display: flex;
  gap: 16rpx;
}

.feature-item {
  flex: 1;
  background: #f3ede3;
  border-radius: 22rpx;
  padding: 20rpx 18rpx;
}

.feature-label {
  display: block;
  font-size: 20rpx;
  color: #9d917f;
  margin-bottom: 10rpx;
}

.feature-value {
  font-size: 26rpx;
  color: #2e342d;
  font-weight: 600;
}

.action-card {
  margin-top: 26rpx;
  background: #1f3a2e;
  border-radius: 30rpx;
  padding: 32rpx 28rpx;
}

.action-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.35;
  color: #fffdf8;
  font-weight: 700;
}

.action-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 253, 248, 0.74);
}

.cta-button {
  width: 100%;
  min-height: 92rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #c96f3b;
  color: #fffdf8;
  font-size: 30rpx;
  font-weight: 700;
}

.login-btn {
  margin-top: 28rpx;
}
