.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(201, 111, 59, 0.14), transparent 26%),
    linear-gradient(180deg, #fbf7ef 0%, #f3ecdf 100%);
}

.summary-card,
.panel-card,
.empty-card {
  padding: 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  background: rgba(255, 251, 245, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(53, 44, 30, 0.08);
}

.panel-card,
.action-row {
  margin-top: 20rpx;
}

.summary-eyebrow {
  display: block;
  font-size: 18rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.summary-title,
.empty-title {
  display: block;
  margin-top: 10rpx;
  font-size: 52rpx;
  line-height: 1.08;
  color: #1e2b23;
  font-weight: 700;
}

.summary-desc,
.empty-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #857a67;
}

.stat-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-item {
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(30, 59, 47, 0.05);
}

.stat-item-danger {
  background: rgba(201, 111, 59, 0.12);
}

.stat-value {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #1e2b23;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #857a67;
}

.panel-head,
.status-top,
.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.panel-title {
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.panel-tip {
  font-size: 22rpx;
  color: #9a8d78;
}

.status-list,
.record-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.status-item,
.record-item {
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(30, 59, 47, 0.04);
}

.status-name,
.record-title {
  font-size: 28rpx;
  color: #1e2b23;
  font-weight: 700;
}

.status-badge {
  min-width: 88rpx;
  height: 56rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.status-badge-text {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
}

.status-badge-danger {
  background: rgba(201, 111, 59, 0.18);
  color: #a8562d;
}

.status-badge-danger .status-badge-text {
  color: #a8562d;
}

.status-badge-normal {
  background: rgba(30, 59, 47, 0.1);
  color: #1e3b2f;
}

.status-badge-normal .status-badge-text {
  color: #1e3b2f;
}

.status-line,
.status-action,
.record-meta,
.record-content,
.record-note,
.empty-inline {
  display: block;
  color: #857a67;
}

.status-line,
.record-meta,
.record-note,
.empty-inline {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.65;
}

.status-action {
  margin-top: 12rpx;
  font-size: 23rpx;
  color: #c96f3b;
}

.record-content {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.action-btn {
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.action-btn-primary {
  background: #c96f3b;
  color: #fff8ef;
}

.action-btn-secondary {
  border: 2rpx solid rgba(30, 59, 47, 0.1);
  background: rgba(30, 59, 47, 0.04);
  color: #1e3b2f;
}
