.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(201, 111, 59, 0.14), transparent 26%),
    linear-gradient(180deg, #fbf7ef 0%, #f3ecdf 100%);
}

.hero-card,
.settings-card,
.preview-card {
  border-radius: 28rpx;
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  background: rgba(255, 251, 245, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(53, 44, 30, 0.08);
}

.hero-card,
.settings-card,
.preview-card {
  padding: 26rpx;
}

.eyebrow {
  display: block;
  font-size: 18rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.hero-title {
  display: block;
  margin-top: 10rpx;
  font-size: 52rpx;
  line-height: 1.04;
  color: #1e2b23;
  font-weight: 700;
}

.hero-sub {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #857a67;
}

.settings-card {
  margin-top: 20rpx;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(30, 59, 47, 0.08);
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-row.stacked {
  display: block;
}

.copy-block {
  flex: 1;
}

.setting-title {
  display: block;
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.setting-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #857a67;
}

.picker-card {
  margin-top: 16rpx;
  min-height: 86rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: rgba(30, 59, 47, 0.05);
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 28rpx;
  color: #1e3b2f;
}

.picker-arrow {
  font-size: 30rpx;
  color: #8c7b68;
}

.preview-card {
  margin-top: 20rpx;
}

.preview-label {
  display: block;
  font-size: 18rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.preview-title {
  display: block;
  margin-top: 12rpx;
  font-size: 32rpx;
  color: #1e2b23;
  font-weight: 700;
}

.preview-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #857a67;
  line-height: 1.7;
}

.save-btn {
  margin-top: 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 22rpx;
  background: #c96f3b;
  color: #fff8ef;
  font-size: 30rpx;
  font-weight: 700;
}
