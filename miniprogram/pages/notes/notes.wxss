.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(201, 111, 59, 0.12), transparent 26%),
    linear-gradient(180deg, #fffdf8 0%, #f5f1e8 100%);
}

.hero-card,
.toolbar-card,
.note-card,
.empty-card,
.editor-panel {
  border-radius: 28rpx;
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  background: rgba(255, 251, 245, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(53, 44, 30, 0.08);
}

.hero-card {
  padding: 28rpx;
}

.eyebrow,
.editor-eyebrow {
  display: block;
  font-size: 18rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.hero-title {
  display: block;
  margin-top: 10rpx;
  font-size: 52rpx;
  line-height: 1.04;
  color: #1e2b23;
  font-weight: 700;
}

.hero-sub {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #857a67;
}

.toolbar-card {
  margin-top: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.toolbar-copy {
  flex: 1;
}

.toolbar-title {
  display: block;
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.toolbar-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #857a67;
}

.toolbar-btn {
  width: 188rpx;
  flex-shrink: 0;
}

.cta-button {
  min-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}

.cta-primary {
  background: #c96f3b;
  color: #fff8ef;
}

.cta-secondary {
  background: rgba(30, 59, 47, 0.05);
  color: #1e3b2f;
  border: 1rpx solid rgba(30, 59, 47, 0.08);
}

.cta-soft {
  background: #efe6d6;
  color: #1e3b2f;
}

.empty-card {
  margin-top: 20rpx;
  padding: 46rpx 28rpx;
  text-align: center;
}

.empty-mark {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.empty-title {
  display: block;
  margin-top: 12rpx;
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.empty-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #857a67;
}

.note-stack {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.note-card {
  padding: 24rpx;
}

.note-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.author-wrap {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.author-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ddd5c9;
}

.author-avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1e3b2f;
  color: #fff8ef;
  font-size: 28rpx;
  font-weight: 700;
}

.author-name {
  display: block;
  font-size: 28rpx;
  color: #1e2b23;
  font-weight: 700;
}

.note-time {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8c8374;
}

.note-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.note-link {
  font-size: 24rpx;
  color: #2e6b5b;
}

.note-link.danger {
  color: #c96f3b;
}

.note-content {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #27352d;
  white-space: pre-wrap;
}

.note-image {
  width: 100%;
  margin-top: 18rpx;
  border-radius: 20rpx;
  background: #f1ece3;
}

.editor-mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 27, 23, 0.42);
  display: flex;
  align-items: flex-end;
  z-index: 20;
}

.editor-panel {
  width: 100%;
  padding: 28rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 30rpx 30rpx 0 0;
  box-sizing: border-box;
}

.editor-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.editor-title {
  display: block;
  margin-top: 8rpx;
  font-size: 38rpx;
  color: #1e2b23;
  font-weight: 700;
}

.editor-close {
  font-size: 46rpx;
  color: #988f7f;
}

.editor-textarea {
  width: 100%;
  height: 240rpx;
  margin-top: 24rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(30, 59, 47, 0.04);
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1e2b23;
}

.image-block {
  margin-top: 20rpx;
}

.editor-image,
.image-placeholder {
  width: 100%;
  height: 240rpx;
  border-radius: 20rpx;
  background: rgba(30, 59, 47, 0.04);
}

.image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8c8374;
  font-size: 24rpx;
  text-align: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.image-actions,
.editor-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.image-btn,
.editor-actions .cta-button {
  flex: 1;
}
