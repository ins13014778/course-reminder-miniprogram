page {
  background:
    radial-gradient(circle at top right, rgba(201, 111, 59, 0.14), transparent 26%),
    linear-gradient(180deg, #fbf7ef 0%, #f3ecdf 100%);
}

.page-shell {
  min-height: 100vh;
  padding: 26rpx 24rpx 56rpx;
  box-sizing: border-box;
}

.hero-card,
.board-card,
.progress-card,
.announcement-card,
.week-section {
  border-radius: 28rpx;
  box-shadow: 0 18rpx 42rpx rgba(53, 44, 30, 0.08);
}

.hero-card {
  padding: 28rpx;
  background: linear-gradient(160deg, #1e3b2f 0%, #27493a 100%);
  color: #fff8ef;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.eyebrow {
  display: block;
  font-size: 18rpx;
  letter-spacing: 6rpx;
  color: rgba(255, 248, 239, 0.64);
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 52rpx;
  line-height: 1.05;
  font-weight: 700;
}

.hero-mark {
  width: 96rpx;
  height: 96rpx;
  border-radius: 26rpx;
  background: rgba(255, 248, 239, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  flex-shrink: 0;
}

.hero-profile {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 239, 0.08);
}

.hero-profile.guest {
  border: 1rpx solid rgba(255, 248, 239, 0.12);
}

.avatar,
.avatar-placeholder {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 248, 239, 0.18);
  font-size: 28rpx;
}

.hero-greeting {
  font-size: 22rpx;
  color: rgba(255, 248, 239, 0.72);
}

.hero-name {
  display: block;
  margin-top: 6rpx;
  font-size: 34rpx;
  color: #fff8ef;
  font-weight: 700;
}

.week-section,
.announcement-card,
.board-card,
.progress-card {
  margin-top: 22rpx;
  padding: 22rpx;
  background: rgba(255, 251, 245, 0.9);
  border: 1rpx solid rgba(30, 59, 47, 0.08);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  color: #1e2b23;
  font-weight: 700;
}

.announcement-title {
  display: block;
  margin-top: 16rpx;
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.announcement-content {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6d6558;
}

.section-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #efe6d6;
  color: #6d6558;
  font-size: 22rpx;
}

.template-note {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #8b6e59;
}

.week-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.week-track {
  display: flex;
  gap: 12rpx;
}

.week-pill {
  flex-shrink: 0;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(30, 59, 47, 0.05);
  color: #6d6558;
  font-size: 24rpx;
}

.week-pill.active {
  background: #1e3b2f;
  color: #fff8ef;
}

.today-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.today-item {
  display: grid;
  grid-template-columns: 120rpx 1fr;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(30, 59, 47, 0.08);
}

.time-box {
  border-radius: 18rpx;
  background: #efe6d6;
  padding: 18rpx 10rpx;
  text-align: center;
}

.time-start {
  display: block;
  font-size: 24rpx;
  color: #1e3b2f;
  font-weight: 700;
}

.time-end {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #6d6558;
}

.course-name {
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.meta-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(46, 107, 91, 0.08);
  color: #476356;
  font-size: 22rpx;
}

.empty-box {
  margin-top: 18rpx;
  padding: 42rpx 24rpx;
  border-radius: 22rpx;
  border: 1rpx dashed rgba(30, 59, 47, 0.16);
  text-align: center;
}

.empty-mark {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.empty-title {
  display: block;
  margin-top: 12rpx;
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.empty-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #857a67;
}

.cta-button {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}

.cta-soft {
  margin-top: 22rpx;
  background: #efe6d6;
  color: #1e3b2f;
}

.action-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.action-grid .cta-button {
  min-height: 102rpx;
  border-radius: 22rpx;
}

.cta-primary {
  background: #c96f3b;
  color: #fff8ef;
}

.primary-span {
  grid-column: 1 / -1;
}

.cta-secondary {
  background: rgba(255, 251, 245, 0.9);
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  color: #1e3b2f;
}

.progress-rail {
  margin-top: 18rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(30, 59, 47, 0.1);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #c96f3b 0%, #e0935f 100%);
}
