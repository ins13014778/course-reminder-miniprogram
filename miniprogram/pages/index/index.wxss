page {
  background: #f6f7f8;
  padding-bottom: 120rpx;
}

.container {
  min-height: 100vh;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: rgba(246, 247, 248, 0.8);
  backdrop-filter: blur(20rpx);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(28, 116, 233, 0.2);
}

.avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(28, 116, 233, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(28, 116, 233, 0.1);
  font-size: 40rpx;
}

.welcome {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 24rpx;
  color: #64748b;
}

.username {
  font-size: 32rpx;
  font-weight: bold;
}

.notification-btn {
  position: relative;
  padding: 10rpx;
}

.notification-btn .icon {
  font-size: 40rpx;
}

.badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 16rpx;
  height: 16rpx;
  background: #1c74e9;
  border-radius: 50%;
}

/* 周次选择器 */
.week-selector {
  padding: 20rpx 0;
  background: white;
  border-bottom: 1rpx solid #f1f5f9;
}

.week-scroll {
  white-space: nowrap;
}

.week-list {
  display: flex;
  padding: 0 20rpx;
}

.week-item {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #64748b;
  background: #f1f5f9;
  border-radius: 30rpx;
  transition: all 0.2s;
}

.week-item.active {
  background: #4F46E5;
  color: white;
  font-weight: 600;
}

/* 课程区域 */
.courses-section {
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-header .title {
  font-size: 32rpx;
  font-weight: bold;
}

.badge-count {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  background: rgba(28, 116, 233, 0.1);
  color: #1c74e9;
  border-radius: 30rpx;
  font-weight: 600;
}

.course-card {
  display: flex;
  gap: 0;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.color-bar {
  width: 8rpx;
  background: var(--card-color, #4F46E5);
}

.time-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-right: 30rpx;
  border-right: 2rpx solid #f1f5f9;
  min-width: 120rpx;
}

.start-time {
  font-size: 32rpx;
  font-weight: bold;
  color: #1c74e9;
}

.end-time {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 24rpx;
}

.course-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  color: #1e293b;
}

.course-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.teacher {
  font-size: 24rpx;
  color: #64748b;
}

.location {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.location .icon {
  font-size: 24rpx;
}

.location .text {
  font-size: 24rpx;
  color: #64748b;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  background: rgba(241, 245, 249, 0.5);
  border-radius: 20rpx;
  border: 2rpx dashed #cbd5e1;
}

.empty-state .icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  font-size: 26rpx;
  color: #64748b;
}

/* 操作按钮 */
.action-buttons {
  padding: 0 30rpx;
  margin-top: 30rpx;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
  background: #1c74e9;
  color: white;
  padding: 30rpx;
  border-radius: 20rpx;
  font-weight: bold;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(28, 116, 233, 0.2);
}

.btn-row {
  display: flex;
  gap: 20rpx;
}

.btn-secondary {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: white;
  color: #334155;
  padding: 30rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 600;
  font-size: 26rpx;
  border: 2rpx solid #e2e8f0;
}

/* 学期进度 */
.progress-section {
  margin: 30rpx;
  padding: 30rpx;
  background: rgba(28, 116, 233, 0.05);
  border: 2rpx solid rgba(28, 116, 233, 0.1);
  border-radius: 20rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-header .title {
  font-size: 28rpx;
  font-weight: bold;
}

.week-info {
  font-size: 22rpx;
  color: #1c74e9;
  font-weight: bold;
}

.progress-bar {
  height: 12rpx;
  background: #cbd5e1;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #1c74e9;
  border-radius: 10rpx;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  background: white;
  padding: 16rpx 0 50rpx;
  border-top: 1rpx solid #f1f5f9;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: #94a3b8;
}

.nav-item.active {
  color: #1c74e9;
}

.nav-item .icon {
  font-size: 40rpx;
}

.nav-item .label {
  font-size: 20rpx;
  font-weight: 600;
}
