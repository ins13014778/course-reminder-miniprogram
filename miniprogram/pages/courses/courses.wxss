.container {
  min-height: 100vh;
  background: #f6f7f8;
  padding: 20rpx 20rpx 140rpx;
}

.week-tabs {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 12rpx;
  margin-bottom: 24rpx;
  gap: 8rpx;
}

.week-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #64748b;
  border-radius: 12rpx;
}

.week-tab.active {
  background: #4f46e5;
  color: #ffffff;
  font-weight: 600;
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.page-tip {
  background: #eef2ff;
  color: #4f46e5;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.course-card {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-content {
  flex: 1;
  padding: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.course-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
}

.header-tags {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.period-tag {
  font-size: 22rpx;
  color: #4f46e5;
  background: #eef2ff;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.section-info {
  font-size: 22rpx;
  color: #94a3b8;
  background: #f1f5f9;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.time-row {
  margin: 16rpx 0;
}

.time-chip {
  display: inline-block;
  font-size: 22rpx;
  color: #0f766e;
  background: #ecfeff;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.card-body {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.icon {
  font-size: 24rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}

.empty-subtext {
  font-size: 24rpx;
  color: #cbd5e1;
  margin-top: 12rpx;
}

.login-link {
  font-size: 28rpx;
  color: #4f46e5;
  margin-top: 18rpx;
}

.loading {
  text-align: center;
  padding: 60rpx;
  color: #94a3b8;
}

.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  background: #4f46e5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(79, 70, 229, 0.4);
  z-index: 100;
}

.add-icon {
  font-size: 60rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  background: #ffffff;
  padding: 16rpx 0 50rpx;
  border-top: 1rpx solid #f1f5f9;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  color: #94a3b8;
}

.nav-item.active {
  color: #4f46e5;
}

.nav-item .icon {
  font-size: 40rpx;
}

.nav-item .label {
  font-size: 22rpx;
}
