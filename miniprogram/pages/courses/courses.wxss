.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(201, 111, 59, 0.14), transparent 26%),
    linear-gradient(180deg, #fbf7ef 0%, #f3ecdf 100%);
}

.headline-card,
.tabs-card,
.course-card,
.empty-card,
.loading-card,
.editor-panel {
  border-radius: 28rpx;
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  box-shadow: 0 18rpx 42rpx rgba(53, 44, 30, 0.08);
}

.headline-card,
.tabs-card,
.empty-card,
.loading-card {
  background: rgba(255, 251, 245, 0.92);
}

.headline-card {
  padding: 26rpx;
}

.eyebrow,
.editor-eyebrow {
  display: block;
  font-size: 18rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.headline-title {
  display: block;
  margin-top: 10rpx;
  font-size: 52rpx;
  line-height: 1.04;
  color: #1e2b23;
  font-weight: 700;
}

.headline-sub {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #857a67;
}

.tabs-card {
  margin-top: 18rpx;
  padding: 12rpx;
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.tab-pill {
  flex-shrink: 0;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #6d6558;
  background: rgba(30, 59, 47, 0.05);
}

.tab-pill.active {
  background: #1e3b2f;
  color: #fff8ef;
}

.course-stack {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.template-tip {
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(201, 111, 59, 0.12);
  color: #8b5f45;
  font-size: 24rpx;
  line-height: 1.6;
}

.course-card {
  display: flex;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.78);
}

.accent-bar {
  width: 10rpx;
  flex-shrink: 0;
}

.course-main {
  flex: 1;
  padding: 20rpx 18rpx;
}

.course-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.title-wrap {
  flex: 1;
}

.course-name {
  display: block;
  font-size: 32rpx;
  color: #1e2b23;
  font-weight: 700;
}

.course-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7b715f;
}

.time-pill {
  align-self: flex-start;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #efe6d6;
  color: #5f574c;
  font-size: 22rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.meta-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(46, 107, 91, 0.08);
  color: #476356;
  font-size: 22rpx;
}

.empty-card,
.loading-card {
  margin-top: 20rpx;
  padding: 42rpx 26rpx;
  text-align: center;
}

.empty-card.compact {
  margin-top: 0;
}

.empty-mark {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.empty-title,
.loading-text {
  display: block;
  margin-top: 12rpx;
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.empty-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #857a67;
}

.cta-button {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}

.cta-primary {
  margin-top: 22rpx;
  background: #c96f3b;
  color: #fff8ef;
}

.fab {
  position: fixed;
  right: 34rpx;
  bottom: 198rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #c96f3b;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 34rpx rgba(201, 111, 59, 0.28);
}

.fab-text {
  color: #fff8ef;
  font-size: 54rpx;
}

.editor-mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 27, 23, 0.42);
  display: flex;
  align-items: flex-end;
  z-index: 20;
}

.editor-panel {
  width: 100%;
  background: #fffaf3;
  border-radius: 30rpx 30rpx 0 0;
  padding: 28rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.editor-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.editor-title {
  display: block;
  margin-top: 8rpx;
  font-size: 38rpx;
  color: #1e2b23;
  font-weight: 700;
}

.editor-close {
  font-size: 46rpx;
  color: #988f7f;
}

.editor-block {
  margin-bottom: 18rpx;
}

.editor-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #6d6558;
}

.editor-input {
  width: 100%;
  min-height: 84rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: rgba(30, 59, 47, 0.04);
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1e2b23;
}

.choice-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.choice-pill {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(30, 59, 47, 0.04);
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  color: #6d6558;
  font-size: 24rpx;
}

.choice-pill.active {
  background: #1e3b2f;
  color: #fff8ef;
}

.week-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.week-input {
  flex: 1;
  text-align: center;
}

.week-join {
  color: #6d6558;
  font-size: 28rpx;
}

.editor-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8a7f6d;
}

.editor-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 28rpx;
}

.editor-btn {
  flex: 1;
  height: 86rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.editor-cancel {
  background: #efe6d6;
  color: #1e3b2f;
}

.editor-save {
  background: #c96f3b;
  color: #fff8ef;
}
