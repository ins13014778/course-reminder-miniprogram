.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(201, 111, 59, 0.14), transparent 26%),
    linear-gradient(180deg, #fbf7ef 0%, #f3ecdf 100%);
}

.headline-card,
.share-import-card,
.upload-card,
.status-card,
.summary-card,
.preview-card {
  border-radius: 28rpx;
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  background: rgba(255, 251, 245, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(53, 44, 30, 0.08);
}

.headline-card,
.share-import-card,
.status-card,
.summary-card,
.preview-card {
  padding: 26rpx;
}

.eyebrow {
  display: block;
  font-size: 18rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.headline-title {
  display: block;
  margin-top: 10rpx;
  font-size: 52rpx;
  line-height: 1.04;
  color: #1e2b23;
  font-weight: 700;
}

.headline-sub,
.status-sub,
.summary-sub,
.upload-sub {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #857a67;
}

.upload-card {
  margin-top: 20rpx;
  min-height: 360rpx;
  padding: 38rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  border-style: dashed;
}

.template-entry-card {
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  background: rgba(255, 251, 245, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(53, 44, 30, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.share-import-card {
  margin-top: 18rpx;
}

.entry-copy {
  flex: 1;
}

.entry-actions {
  display: flex;
  flex-shrink: 0;
  gap: 12rpx;
}

.entry-title {
  display: block;
  font-size: 28rpx;
  color: #1e2b23;
  font-weight: 700;
}

.entry-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #857a67;
}

.entry-btn {
  min-width: 176rpx;
}

.share-input {
  margin-top: 16rpx;
  width: 100%;
  min-height: 88rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: rgba(30, 59, 47, 0.05);
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  font-size: 28rpx;
  color: #1e2b23;
}

.share-import-btn {
  margin-top: 16rpx;
}

.upload-mark,
.summary-mark {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.upload-title,
.status-title,
.summary-title {
  display: block;
  margin-top: 12rpx;
  font-size: 34rpx;
  color: #1e2b23;
  font-weight: 700;
  text-align: center;
}

.status-card {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.status-card.failed {
  align-items: stretch;
}

.spinner {
  width: 82rpx;
  height: 82rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(30, 59, 47, 0.12);
  border-top-color: #c96f3b;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.result-stack {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.card-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #efe6d6;
  color: #6d6558;
  font-size: 22rpx;
}

.preview-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(30, 59, 47, 0.08);
}

.preview-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.preview-name {
  display: block;
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.preview-meta,
.raw-text {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6d6558;
  line-height: 1.7;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 14rpx;
}

.cta-button {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}

.cta-primary {
  background: #c96f3b;
  color: #fff8ef;
}

.cta-secondary {
  background: rgba(30, 59, 47, 0.05);
  color: #1e3b2f;
  border: 1rpx solid rgba(30, 59, 47, 0.08);
}

.cta-primary.solo {
  margin-top: 20rpx;
}
