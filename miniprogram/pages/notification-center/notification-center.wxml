<view class="page-shell">
  <view class="hero-card">
    <text class="eyebrow">NOTIFICATION HUB</text>
    <text class="hero-title">{{title}}</text>
    <text class="hero-sub">{{subtitle}}</text>
  </view>

  <view class="panel-card">
    <text class="panel-title">页面说明</text>
    <text class="panel-copy">{{content}}</text>
  </view>

  <view class="panel-card" wx:if="{{tips.length}}">
    <text class="panel-title">使用建议</text>
    <view class="tip-list">
      <view class="tip-item" wx:for="{{tips}}" wx:key="index">
        <text class="tip-index">{{index + 1}}</text>
        <text class="tip-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="panel-card" wx:if="{{feedbackUpdates.length}}">
    <text class="panel-title">反馈处理通知</text>
    <view class="tip-list">
      <view class="tip-item" wx:for="{{feedbackUpdates}}" wx:key="id">
        <text class="tip-index">回</text>
        <view class="tip-content">
          <text class="tip-text">{{item.title}} · {{item.status === 'reviewed' ? '已处理' : '已归档'}}</text>
          <text class="tip-sub">{{item.admin_note || '后台已经处理了你的反馈，可回到留言反馈页面查看详情。'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="panel-card" wx:if="{{appealUpdates.length}}">
    <text class="panel-title">申诉审核通知</text>
    <view class="tip-list">
      <view class="tip-item" wx:for="{{appealUpdates}}" wx:key="id">
        <text class="tip-index">诉</text>
        <view class="tip-content">
          <text class="tip-text">{{item.title}} · {{item.status === 'approved' ? '申诉通过' : '申诉驳回'}}</text>
          <text class="tip-sub">{{item.admin_note || (item.status === 'approved' ? '后台已通过你的申诉，对应限制已解除。' : '后台已驳回你的申诉，可回到申诉中心查看详情。')}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="action-btn" bindtap="onOpenPrimaryAction">{{primaryActionText}}</view>
</view>
