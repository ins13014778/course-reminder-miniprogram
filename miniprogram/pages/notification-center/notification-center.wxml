<view class="page-shell">
  <view class="hero-card">
    <text class="eyebrow">NOTIFICATION HUB</text>
    <text class="hero-title">{{title}}</text>
    <text class="hero-sub">{{subtitle}}</text>
  </view>

  <view class="summary-card" wx:if="{{isLoggedIn}}">
    <view>
      <text class="summary-label">未读消息</text>
      <text class="summary-value">{{unreadCount}}</text>
    </view>
    <view class="summary-action" wx:if="{{unreadCount}}" bindtap="onMarkAllRead">全部已读</view>
  </view>

  <view class="panel-card">
    <text class="panel-title">页面说明</text>
    <text class="panel-copy">{{content}}</text>
  </view>

  <view class="panel-card" wx:if="{{tips.length}}">
    <text class="panel-title">使用建议</text>
    <view class="tip-list">
      <view class="tip-item" wx:for="{{tips}}" wx:key="index">
        <text class="tip-index">{{index + 1}}</text>
        <text class="tip-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="panel-card">
    <view class="title-row">
      <text class="panel-title">系统消息中心</text>
      <text class="panel-subcopy">{{isLoggedIn ? '含公告、反馈回执、申诉回执' : '登录后可查看反馈与申诉回执'}}</text>
    </view>

    <view class="empty-box" wx:if="{{!messageItems.length}}">
      <text class="empty-title">当前还没有消息</text>
      <text class="empty-sub">新公告、反馈回执和申诉结果会显示在这里。</text>
    </view>

    <view class="message-list" wx:else>
      <view
        class="message-item {{item.isRead ? 'is-read' : 'is-unread'}}"
        wx:for="{{messageItems}}"
        wx:key="message_key"
        data-type="{{item.message_type}}"
        data-id="{{item.message_id}}"
        bindtap="onMessageTap"
      >
        <view class="message-top">
          <view class="message-badge-row">
            <text class="message-badge">{{item.badgeText}}</text>
            <text class="message-status">{{item.statusText}}</text>
          </view>
          <view class="message-side">
            <text wx:if="{{!item.isRead}}" class="message-dot"></text>
            <text class="message-time">{{item.timeText}}</text>
          </view>
        </view>
        <text class="message-title">{{item.title}}</text>
        <text class="message-detail">{{item.detailText}}</text>
      </view>
    </view>
  </view>

  <view class="action-btn" bindtap="onOpenPrimaryAction">{{primaryActionText}}</view>
</view>
