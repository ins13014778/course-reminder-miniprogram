.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(201, 111, 59, 0.14), transparent 26%),
    linear-gradient(180deg, #fbf7ef 0%, #f3ecdf 100%);
}

.hero-card,
.panel-card {
  padding: 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  background: rgba(255, 251, 245, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(53, 44, 30, 0.08);
}

.panel-card {
  margin-top: 20rpx;
}

.eyebrow {
  display: block;
  font-size: 18rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.hero-title {
  display: block;
  margin-top: 10rpx;
  font-size: 52rpx;
  line-height: 1.04;
  color: #1e2b23;
  font-weight: 700;
}

.hero-sub,
.panel-copy,
.tip-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.8;
  color: #857a67;
}

.hero-sub {
  margin-top: 14rpx;
}

.panel-title {
  display: block;
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.panel-copy {
  margin-top: 14rpx;
  white-space: pre-wrap;
}

.tip-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(30, 59, 47, 0.04);
}

.tip-content {
  flex: 1;
}

.tip-index {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #1e3b2f;
  color: #fff8ef;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #857a67;
}

.action-btn {
  margin-top: 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 22rpx;
  background: #c96f3b;
  color: #fff8ef;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}
