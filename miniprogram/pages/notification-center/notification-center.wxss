.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(201, 111, 59, 0.14), transparent 26%),
    linear-gradient(180deg, #fbf7ef 0%, #f3ecdf 100%);
}

.hero-card,
.panel-card,
.summary-card {
  padding: 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(30, 59, 47, 0.08);
  background: rgba(255, 251, 245, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(53, 44, 30, 0.08);
}

.panel-card,
.summary-card {
  margin-top: 20rpx;
}

.eyebrow {
  display: block;
  font-size: 18rpx;
  letter-spacing: 6rpx;
  color: #c96f3b;
}

.hero-title {
  display: block;
  margin-top: 10rpx;
  font-size: 52rpx;
  line-height: 1.04;
  color: #1e2b23;
  font-weight: 700;
}

.hero-sub,
.panel-copy,
.tip-text,
.message-detail {
  display: block;
  font-size: 24rpx;
  line-height: 1.8;
  color: #857a67;
}

.hero-sub {
  margin-top: 14rpx;
}

.panel-title {
  display: block;
  font-size: 30rpx;
  color: #1e2b23;
  font-weight: 700;
}

.panel-copy {
  margin-top: 14rpx;
  white-space: pre-wrap;
}

.tip-list,
.message-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item,
.message-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(30, 59, 47, 0.04);
}

.message-item {
  display: block;
}

.message-item.is-unread {
  border: 1rpx solid rgba(201, 111, 59, 0.28);
  background: rgba(201, 111, 59, 0.07);
}

.message-item.is-read {
  opacity: 0.78;
}

.tip-index {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #1e3b2f;
  color: #fff8ef;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: #857a67;
}

.summary-value {
  display: block;
  margin-top: 8rpx;
  font-size: 54rpx;
  font-weight: 700;
  color: #1e2b23;
}

.summary-action {
  padding: 16rpx 22rpx;
  border-radius: 18rpx;
  background: #1e3b2f;
  color: #fff8ef;
  font-size: 24rpx;
  font-weight: 700;
}

.title-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.panel-subcopy {
  font-size: 22rpx;
  color: #857a67;
}

.message-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.message-badge-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.message-badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(30, 59, 47, 0.1);
  color: #1e3b2f;
  font-size: 20rpx;
  font-weight: 700;
}

.message-status,
.message-time {
  font-size: 22rpx;
  color: #857a67;
}

.message-side {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.message-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c96f3b;
}

.message-title {
  display: block;
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #1e2b23;
  font-weight: 700;
}

.message-detail {
  margin-top: 8rpx;
}

.empty-box {
  margin-top: 18rpx;
  padding: 28rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(30, 59, 47, 0.04);
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1e2b23;
}

.empty-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #857a67;
}

.action-btn {
  margin-top: 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 22rpx;
  background: #c96f3b;
  color: #fff8ef;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}
